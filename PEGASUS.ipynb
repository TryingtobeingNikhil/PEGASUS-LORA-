    {
      "cell_type": "code",
      "source": [
        "from torch.utils.data import Dataset\n",
        "\n",
        "# Your training data\n",
        "train_documents = [\n",
        "    \"The new smartphone features a 6.7-inch OLED display with 120Hz refresh rate. It's powered by the latest Snapdragon processor and includes a 5000mAh battery. The camera system has three lenses including a 108MP main sensor. Storage options range from 128GB to 512GB. Price starts at $899.\",\n",
        "    \"Researchers discovered a new species of deep-sea fish near the Mariana Trench. The fish can survive at depths exceeding 8000 meters where pressure is extreme. It has unique bioluminescent organs and transparent skin. The discovery expands our understanding of extreme environment adaptations.\",\n",
        "    \"The city council approved a $50 million budget for renewable energy projects. Solar panels will be installed on public buildings. New wind turbines will be constructed outside the city. The initiative aims to achieve 40% renewable energy by 2030. Environmental groups praised the decision.\",\n",
        "]\n",
        "\n",
        "train_summaries = [\n",
        "    \"New smartphone launched with advanced display, powerful processor, high-capacity battery, and premium camera for $899.\",\n",
        "    \"Scientists found new deep-sea fish species in Mariana Trench with unique adaptations to extreme pressure.\",\n",
        "    \"City allocates $50M for solar and wind energy projects targeting 40% renewable energy by 2030.\",\n",
        "]\n",
        "\n",
        "# The streamlined Dataset class\n",
        "class SumDataset(Dataset):\n",
        "    def __init__(self, docs, sums):\n",
        "        self.docs = docs\n",
        "        self.sums = sums\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.docs)\n",
        "\n",
        "    def __getitem__(self, i):\n",
        "        # Assumes 'tokenizer' is already defined in your Colab environment\n",
        "        inp = tokenizer(self.docs[i], max_length=512, truncation=True, padding=\"max_length\", return_tensors=\"pt\")\n",
        "        tgt = tokenizer(self.sums[i], max_length=128, truncation=True, padding=\"max_length\", return_tensors=\"pt\")\n",
        "\n",
        "        labels = tgt[\"input_ids\"].clone()\n",
        "        labels[labels == tokenizer.pad_token_id] = -100\n",
        "\n",
        "        return {\n",
        "            \"input_ids\": inp[\"input_ids\"].squeeze(),\n",
        "            \"attention_mask\": inp[\"attention_mask\"].squeeze(),\n",
        "            \"labels\": labels.squeeze()\n",
        "        }\n",
        "\n",
        "# Instantiate and verify\n",
        "train_ds = SumDataset(train_documents, train_summaries)\n",
        "print(\"Dataset size:\", len(train_ds))\n",
        "print(\"Input shape:\", train_ds[0][\"input_ids\"].shape)"
      ],
